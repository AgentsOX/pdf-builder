{
  "name": "@agentsox/pdf-builder",
  "version": "0.1.0",
  "description": "Agent-first CLI that turns a declarative document spec into a correct, branded PDF (Typst engine).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pdf": "dist/cli.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "fonts",
    "vendor",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pdf": "node dist/cli.js"
  },
  "keywords": [
    "pdf",
    "typst",
    "cli",
    "agent",
    "llm",
    "document",
    "invoice"
  ],
  "dependencies": {
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
